# FalconNet Frontend — variables de entorno
# Copia este archivo a .env.local y ajusta los valores

# URL del backend Spring Boot.
# Para probar desde celular usa la IP local de tu PC, no localhost:
# NEXT_PUBLIC_API_URL=http://192.168.x.x:8080
NEXT_PUBLIC_API_URL=http://localhost:8080

# URL WebSocket (Phase 4: realtime STOMP)
# NEXT_PUBLIC_WS_URL=ws://192.168.x.x:8080/ws
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# URL de la app (opcional, para metadata)
# NEXT_PUBLIC_APP_URL=http://localhost:3000
